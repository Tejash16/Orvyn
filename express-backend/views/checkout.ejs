<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Orvyn — Upgrade to <%= planName %></title>
  <link rel="stylesheet" href="/static/css/checkout.css">
</head>
<body>
  <div class="checkout-page">
    <div class="checkout-container">
      <div class="checkout-header">
        <div class="brand">Orvyn</div>
        <p class="checkout-subtitle">Secure Checkout</p>
      </div>

      <div class="plan-card">
        <h1 class="plan-name">Upgrade to Orvyn <%= planName %></h1>
        <p class="plan-price"><%= formattedPrice %><span class="period">/month</span></p>
        <p class="plan-description"><%= planDescription %></p>
      </div>

      <button id="pay-btn" class="pay-button">
        <svg class="pay-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <rect x="1" y="4" width="22" height="16" rx="2" ry="2"></rect>
          <line x1="1" y1="10" x2="23" y2="10"></line>
        </svg>
        Pay with Razorpay
      </button>

      <p class="secure-note">
        <svg class="lock-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect>
          <path d="M7 11V7a5 5 0 0 1 10 0v4"></path>
        </svg>
        Secured by Razorpay. We never store your card details.
      </p>
    </div>
  </div>

  <script src="https://checkout.razorpay.com/v1/checkout.js"></script>
  <script>
    var options = {
      key: '<%= razorpayKeyId %>',
      subscription_id: '<%= subscriptionId %>',
      name: 'Orvyn',
      description: '<%= planDescription %>',
      handler: function(response) {
        // Payment success — redirect to success page
        window.location.href = '/billing/checkout/success?subscription_id=<%= subscriptionId %>';
      },
      prefill: {
        email: '<%= userEmail %>',
        name: '<%= userName %>',
      },
      theme: { color: '#059669' },
      modal: {
        ondismiss: function() {
          document.getElementById('pay-btn').textContent = 'Try Again';
        }
      }
    };

    document.getElementById('pay-btn').onclick = function() {
      var rzp = new Razorpay(options);
      rzp.open();
    };
  </script>
</body>
</html>
