<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Orvyn — Organization Invite</title>
  <link rel="stylesheet" href="/static/css/invite.css">
</head>
<body>
  <div class="invite-page">
    <div class="invite-container">
      <div class="invite-header">
        <div class="brand">Orvyn</div>
        <p class="invite-subtitle">Organization Invite</p>
      </div>

      <% if (error) { %>
        <div class="result-icon failure-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="10"></circle>
            <line x1="15" y1="9" x2="9" y2="15"></line>
            <line x1="9" y1="9" x2="15" y2="15"></line>
          </svg>
        </div>
        <h1 class="result-title result-title-failure">Invite unavailable</h1>
        <p class="result-message"><%= error %></p>
        <p class="result-hint">Ask your team admin to send a new invite.</p>
      <% } else { %>
        <div class="invite-card">
          <p class="invite-eyebrow">You've been invited to join</p>
          <h1 class="invite-org"><%= orgName %></h1>
          <p class="invite-meta">
            by <strong><%= inviterName %></strong> as <strong><%= role %></strong>
          </p>
          <p class="invite-expiry">Expires on <%= expiryDate %></p>
        </div>

        <a id="open-btn" href="<%= deepLink %>" class="primary-button">
          <svg class="btn-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"></path>
            <path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"></path>
          </svg>
          Open in Orvyn
        </a>

        <div class="divider"><span>or</span></div>

        <div class="code-block">
          <p class="code-label">Enter this code manually in Orvyn</p>
          <div class="code-row">
            <code id="invite-code"><%= inviteCode %></code>
            <button id="copy-btn" type="button" class="copy-button" aria-label="Copy code">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect>
                <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
              </svg>
            </button>
          </div>
        </div>

        <p class="download-note">
          Don't have Orvyn installed?
          <a href="https://orvyn.app/download" target="_blank" rel="noopener">Download for Windows</a>
        </p>
      <% } %>
    </div>
  </div>

  <script>
    (function () {
      var copyBtn = document.getElementById('copy-btn');
      if (copyBtn) {
        copyBtn.addEventListener('click', function () {
          var code = document.getElementById('invite-code').textContent.trim();
          if (navigator.clipboard && navigator.clipboard.writeText) {
            navigator.clipboard.writeText(code).then(function () {
              copyBtn.classList.add('copied');
              setTimeout(function () { copyBtn.classList.remove('copied'); }, 1500);
            });
          }
        });
      }
    })();
  </script>
</body>
</html>
