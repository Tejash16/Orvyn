<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Orvyn — Payment Failed</title>
  <link rel="stylesheet" href="/static/css/checkout.css">
</head>
<body>
  <div class="checkout-page">
    <div class="checkout-container result-container">
      <div class="result-icon failure-icon">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <line x1="18" y1="6" x2="6" y2="18"></line>
          <line x1="6" y1="6" x2="18" y2="18"></line>
        </svg>
      </div>
      <h1 class="result-title result-title-failure">Payment Failed</h1>
      <p class="result-message"><%= message %></p>
      <p class="result-hint">If the issue persists, check your payment method or contact your bank.</p>
    </div>
  </div>
</body>
</html>
