PORT=

MONGO_URI=

JWT_SECRET=
REFRESH_TOKEN_SECRET=

ACCESS_TOKEN_TTL=
REFRESH_TOKEN_TTL=

CLIENT_URL=

# Public URL of this Express backend — used to build absolute invite landing
# URLs (https://<APP_URL>/invite/:code) that go into invite emails.
APP_URL=http://localhost:8080

GEMINI_API_KEY=

GEMINI_CHAT_MODEL=gemini-2.5-flash
# Ordered fallback chain: tried left→right when a model returns 403/404/429/500/503/network errors
GEMINI_MODEL_CHAIN=gemini-2.5-flash,gemini-1.5-flash,gemini-1.5-pro
GEMINI_CHAT_TEMPERATURE=0.3
GEMINI_CHAT_MAX_OUTPUT_TOKENS=4096

# === OCR via Gemini Vision ===
GEMINI_OCR_MAX_IMAGE_SIZE_MB=10

# === Embedding model (Copilot) ===
GEMINI_EMBEDDING_MODEL=gemini-embedding-001
GEMINI_EMBEDDING_DIMENSIONS=3072

# === SMTP (transactional email) ===
# All required in production. In dev, emails are logged to file via winston.
SMTP_HOST=
SMTP_PORT=
SMTP_SECURE=
SMTP_USER=
SMTP_PASS=
MAIL_FROM=

# === Google OAuth ===
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Cloud callback URL for Google OAuth (e.g., https://api.orvyn.app/portal/auth/google/callback)
GOOGLE_REDIRECT_URI=

# === Admin Panel ===
# Separate JWT secret for admin tokens (leave blank to fall back to JWT_SECRET)
ADMIN_SESSION_SECRET=
# Comma-separated IP whitelist for admin access (e.g., 103.x.x.x,127.0.0.1)
# Leave blank to allow all IPs (development only — must be set in production)
ADMIN_ALLOWED_IPS=

# === Razorpay (payment processing) ===
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
RAZORPAY_PLAN_ID_PRO=
RAZORPAY_PLAN_ID_ENTERPRISE=